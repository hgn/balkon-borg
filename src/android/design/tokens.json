{
  "meta": {
    "name": "Balkon-Borg",
    "style": "Material 3 Expressive, dark-native mit Light-Variante, Neon/Violett-Akzente",
    "source": "Balkon-Borg App.dc.html"
  },
  "color": {
    "dark": {
      "bg": "#0d0a17",
      "surface": "#17111f",
      "surface2": "#1f1830",
      "surface3": "#291f3d",
      "primary": "#b57bff",
      "primaryStrong": "#8b2fff",
      "accent": "#ff4fd8",
      "cyan": "#35e6ff",
      "text": "#f2ecff",
      "textDim": "#a99bc9",
      "border": "#332a49",
      "danger": "#ff5470",
      "onPrimary": "#ffffff",
      "onDanger": "#ffffff"
    },
    "light": {
      "bg": "#faf8fd",
      "surface": "#ffffff",
      "surface2": "#f3eefb",
      "surface3": "#ece4fa",
      "primary": "#7c3aed",
      "primaryStrong": "#6d28d9",
      "accent": "#d6409f",
      "cyan": "#0891b2",
      "text": "#1c1530",
      "textDim": "#6b6280",
      "border": "#e4def2",
      "danger": "#ff5470",
      "onPrimary": "#ffffff",
      "onDanger": "#ffffff"
    },
    "semantic": {
      "LUMEN": "accent",
      "COMMS": "cyan",
      "SIGINT": "primary",
      "SENTRY": "danger"
    }
  },
  "typography": {
    "fontFamilyBody": "Manrope",
    "fontFamilyMono": "Space Grotesk",
    "weights": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700, "extrabold": 800 },
    "scale": {
      "screenTitle": { "size": 26, "weight": 800, "letterSpacing": -0.01, "family": "body" },
      "birdOfDayTitle": { "size": 30, "weight": 800, "letterSpacing": -0.01, "family": "body" },
      "sheetTitle": { "size": 18, "weight": 800, "family": "body" },
      "cardValueActive": { "size": 22, "weight": 800, "letterSpacing": -0.01, "family": "body" },
      "cardValueOff": { "size": 17, "weight": 600, "family": "body" },
      "nowPlaying": { "size": 20, "weight": 800, "family": "body" },
      "eyebrow": { "size": 11, "weight": 700, "letterSpacing": 0.14, "family": "body", "usage": "Section labels, uppercase" },
      "brandWordmark": { "size": 22, "weight": 800, "letterSpacing": -0.02, "family": "body" },
      "brandEyebrow": { "size": 12, "weight": 600, "letterSpacing": 0.22, "family": "mono" },
      "body": { "size": 15, "weight": 700, "family": "body" },
      "caption": { "size": 13, "weight": 600, "family": "body" },
      "small": { "size": 12, "weight": 600, "family": "body" },
      "micro": { "size": 10, "weight": 600, "family": "body" },
      "monoValue": { "size": 19, "weight": 700, "family": "mono", "usage": "Stat values, time stamps, frequencies" },
      "monoValueLarge": { "size": 26, "weight": 700, "family": "mono", "usage": "Chart value display" }
    }
  },
  "radius": {
    "phoneFrame": 54,
    "screen": 42,
    "sheet": 32,
    "card": 28,
    "sentryCard": 24,
    "statTile": 20,
    "chip": 14,
    "chipWide": 16,
    "badge": 13,
    "birdInitial": 12,
    "bottomNav": 28,
    "navItem": 20,
    "switchTrack": 15,
    "themeToggleTrack": 16,
    "pill": "9999 (fully round: switches, ptt button, dots)"
  },
  "spacing": {
    "screenPaddingX": 22,
    "screenPaddingBottomNav": 120,
    "sectionGap": 22,
    "cardGap": 14,
    "statGap": 10,
    "chipGap": 8,
    "cardPadding": 18,
    "sentryCardPadding": "18 20",
    "sheetPadding": "10 22 30"
  },
  "elevation": {
    "phoneShadow": "0 40px 80px -20px rgba(20,10,40,.35), 0 10px 30px -10px rgba(20,10,40,.25)",
    "bottomNavShadow": "0 12px 30px rgba(0,0,0,.18)",
    "sheetShadow": "0 -20px 50px rgba(0,0,0,.25)",
    "switchThumbShadow": "0 2px 6px rgba(0,0,0,.25)"
  },
  "motion": {
    "springOvershoot": { "curve": "cubic-bezier(.34,1.56,.64,1)", "usage": "Card tap-scale, sheet-row select, switch thumb slide, nav active state, chip select, ptt button resize — every direct-manipulation state change" },
    "sheetEnter": { "curve": "cubic-bezier(.22,1.1,.36,1)", "duration": 380, "usage": "Bottom sheet slide-up" },
    "screenEnter": { "curve": "cubic-bezier(.22,1,.36,1)", "duration": 450, "usage": "Screen/tab content fade+rise on nav switch" },
    "backdropFade": { "curve": "ease", "duration": 250 },
    "themeCrossfade": { "curve": "ease", "duration": 400, "usage": "Background color transition on theme toggle" },
    "tapScaleDown": { "curve": "cubic-bezier(.34,1.56,.64,1)", "duration": 250, "scale": 0.95, "usage": "Card active/press state" },
    "statTapScale": { "scale": 0.94 },
    "pulseDot": { "keyframes": "opacity 1↔.35, scale 1↔1.4", "duration": 1800, "easing": "ease-in-out", "loop": true, "usage": "Live status dot (vision active, LIVE camera indicator uses 1400ms)" },
    "eqBar": { "keyframes": "scaleY .25↔1", "duration": 1000, "easing": "ease-in-out", "loop": true, "stagger": 150, "usage": "Radio equalizer bars while COMMS/SIGINT active" },
    "recPulse": { "keyframes": "box-shadow ring 0→18px fading", "duration": 1100, "easing": "ease-out", "loop": true, "usage": "Push-to-talk button while recording" }
  },
  "iconography": {
    "style": "Single glyph/letter badges, monospace — no illustrative icons",
    "navGlyphs": { "home": "⌂", "camera": "◎", "radio": "≈", "log": "☰" },
    "modeGlyphs": { "LUMEN": "L", "COMMS": "C", "SIGINT": "Σ", "SENTRY": "◈" }
  }
}
